[{
  "include": "~/.config/waybar/custom_modules/modules",
  "layer": "top",
  "height": 30,
  "margin-top": 4,
  "margin-left": 0,
  "margin-bottom": 4,
  "margin-right": 0,
  "spacing": 0,

  "modules-left": [
    "hyprland/workspaces",
    "custom/pacman-update",
    "temperature",
    "custom/media-control"
  ],

  "modules-center": [
    "clock"
  ],

  "modules-right": [
    "tray",
    "backlight",
    "pulseaudio",
    "bluetooth",
    "network",
    "battery",
    "custom/power-menu"
  ],

  "clock": {
    "format": "<b>{:%I:%M %p}</b>",
    "format-alt": "<b>{:%a. %d, %b}</b>",
    "tooltip-format": "<big>{:%B %Y}</big>\n<tt><small>{calendar}</small></tt>"
  },

  "backlight": {
    "device": "intel_backlight",
    "format": "{icon} <b>{percent}</b>",
    "tooltip": false,
    "format-icons": ["", ""],
    "on-scroll-down": "brightnessctl s 5%-",
    "on-scroll-up": "brightnessctl s +5%"
  },

  "pulseaudio": {
    "format": "<b>   {volume}</b>",
    "format-bluetooth": "<b>󰗾 {volume}</b>",
    "format-bluetooth-muted": "<b>󰗿</b>",
    "tooltip": false,
    "format-muted": "  ",
    "on-click": "pavucontrol"
  },
  
  "cpu": {
    "interval": 10,
    "format": " <b>{usage}%</b>",
    "max-length": 10,
    "tooltip": false
  },

  "memory": {
    "interval": 30,
    "format": "﬙ <b>{used}GiB</b>",
    "format-alt": " <b>{used:0.1f}G</b>",
    "max-length": 10
  },

  "temperature": {
    "thermal-zone": 0,
    "critical-threshold": 80,
    "format-critical": " {temperatureC}°C</b>",
    "format": " <b>{temperatureC}°C</b>"
  },

  "hyprland/workspaces": {
    "disable-scroll": true,
    "all-outputs": true,
    "format": "<b>{name}</b>",
    "format-icons": {
      "urgent": "󰗖",
      "default": ""
    }
  },

  "tray": {
    "icon-size": 20,
    "spacing": 4,
    "expand": true,
    "show-passive-items": true
  },

  "battery": {
    "interval": 10,
    "states": {
      "warning": 30,
      "critical": 15
    },
    "format": "<b>{icon}  {capacity}%</b>",
    "format-charging": "<b>{icon}⚡︎ {capacity}%</b>",
    "plugged": "ﮣ",
    "format-icons": [" ", " ", " ", " "],
    "max-length": 25,
    "tooltip": false,
  },

  "network": {
    "format": "<b></b>",
    "format-wifi": "",
    "format-ethernet": "<b>모</b>",
    "tooltip": false,
    "on-click": "bash ~/.config/waybar/scripts/rofi-wifi-menu.sh", 
    "format-disconnected": "<b>⚠</b>",
    "fomrat-disabled": "<b>⚠</b>",
    "interval": 10,
  },

  "bluetooth": {
    "format": "<b>󰂳</b>",
    "format-connected": "<b>󰂯 {num_connections}</b>",
    "format-disabled": "<b>󰂲</b>",
    "interval": 30,
    "on-click" : "bash ~/.config/waybar/scripts/rofi-bluetooth",
    "tooltip": false,
  },
    
   "custom/spotify": {
     "exec": "~/.config/waybar/mediaplayer.py --player spotify",
     "format": "{}  ",
     "return-type": "json",
     "on-click": "playerctl play-pause",
     "on-scroll-up": "playerctl next",
     "on-scroll-down": "playerctl previous"
   }
}]
