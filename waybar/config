[{
  "include": "~/.config/waybar/custom_modules/modules",
  "layer": "bottom",
  "height": 30, 
  "margin-top": -4,
  "margin-left": -5,
  "margin-bottom": 0,
  "margin-right": -5,
  "spacing": 0,

  "modules-left": [
    "hyprland/workspaces",
    "custom/spotify"
  ],

  "modules-center": [
    "clock",
    "group/windows"
  ],

  "modules-right": [
    "group/minimized",
    "group/clickable",
    "battery",
    "custom/power-menu"
  ],

  "clock": {
    "format": "<b>{:%I:%M %p}</b>",
    "format-alt": "<b>{:%a. %d, %b}</b>",
    "tooltip-format": "<big>{:%B %Y}</big>\n<tt><small>{calendar}</small></tt>",
    "on-click-middle": "gnome-calendar",
    "on-click-right": "swaync-client -t -sw", 
    "on-scroll-up": "hyprctl dispatch layoutmsg 'move -col'",
    "on-scroll-down": "hyprctl dispatch layoutmsg 'move +col'"
  },

  "backlight": {
    "device": "intel_backlight",
    "format": "{icon} <b>{percent}</b>",
    "tooltip": false,
    "format-icons": ["п„‘", "п†…"],
    "on-scroll-down": "brightnessctl s 5%-",
    "on-scroll-up": "brightnessctl s +5%",
    "on-click": "better-control -m -d"
  },

  "pulseaudio": {
    "format": "{icon} вЂ‰{volume}",  
    "format-bluetooth": "<b>у°—ѕ  {volume}</b>",
    "format-bluetooth-muted": "<b>у°—ївЂ‰</b>",
    "format-source": "п„°",
    "format-source-muted": "п„±",
    "tooltip": false,
    "format-muted": "о»ЁвЂ‰вЂ‰",
    "on-click": "better-control -m -v",
    "on-click-right": "amixer sset Master toggle 1>/dev/null",
    "format-icons": {
            "headphone": "п–ђ",
            "hands-free": "п–ђ",
            "headset": "п–ђ",
            "phone": "п‚• ",
            "portable": "п‚• ",
            "car": "п†№ ",
            "default": ["пЂ¦", "пЂ§ ", "пЂЁ "]
        },
  },
  
  "cpu": {
    "interval": 10,
    "format": "пЎљ <b>{usage}%</b>",
    "max-length": 10,
    "tooltip": false
  },

  "memory": {
    "interval": 60,
    "format": "<b>п‹›   {used:0.1f} GB</b>",
    "on-click": "kitty -e btop",
    "tooltip-format": "{used:0.2f} / {total:0.2f} GB\n{swapUsed:0.2f} / {swapTotal:0.2f} GB"
  },

  "temperature": {
    "thermal-zone": 0,
    "critical-threshold": 80,
    "format-critical": "п‹‡ {temperatureC}В°C</b>",
    "format": "п‹‡ <b>{temperatureC}В°C</b>",
    "tooltip": false
  },

  "hyprland/workspaces": {
    "disable-scroll": true,
    "all-outputs": false,
    "format": "<b>{name}</b>",
    "format-icons": {
      "urgent": "у°—–",
      "default": "п„‘"
    }
  },

  "tray": {
    "icon-size": 20,
    "spacing": 2,
    "expand": true,
    "show-passive-items": true
  },

  "battery": {
    "bat": "BAT0",
    "interval": 5,
    "states": {
      "warning": 30,
      "critical": 15
    },
    "format": "{icon} <b>{capacity}%</b>",
    "format-charging": "{icon}вЂ‰вЂ‰вљЎпёЋ <b>{capacity}%</b>",
    "on-click": "better-control -m -B",
    "plugged": "п®Ј",
    "format-icons": ["п‰ѓ", "п‰‚", "п‰Ѓ", "п‰Ђ"],
    "max-length": 25,
    "tooltip": false
  },

  "network": {
    "format": "<b>о™”</b>",
    "format-wifi": "п‡«",
    "format-ethernet": "<b>лЄЁ</b>",
    "tooltip": false,
    "on-click": "better-control -m -w", 
    "format-disconnected": "<b>вљ </b>",
    "fomrat-disabled": "<b>вљ </b>"
  },

  "bluetooth": {
    "format": "<b>у°‚і</b>",
    "format-connected": "<b>у°‚Ї {num_connections}</b>",
    "format-on": "<b>у°‚Ї</b>",
    "format-off": "<b>у°‚І</b>",
    "on-click" : "better-control -m -b",
    "on-click-right": "bluetoothctl power $(bluetoothctl show | grep -q 'Powered: yes' && echo off || echo on)",
    "tooltip": false
  },
    
   "custom/spotify": {
     "exec": "~/.config/waybar/mediaplayer.py --player spotify",
     "format": "{} ",
     "return-type": "json",
     "max-length": 30,
     "tooltip": true,
     "tooltip-format": "{}",
     "on-click": "playerctl -p spotify play-pause",
     "on-scroll-up": "playerctl -p spotify previous",
     "on-scroll-down": "playerctl -p spotify next"
   },
   
   "custom/trayexpand": {
    "format": "<b>вЇ‡</b>",
    "tooltip": false
   },

   "custom/windowexpand": {
    "format": "<b>вЇ€</b>",
    "tooltip": false
   },
   
   "custom/appexpand": {
    "format": "<b>о“Ґ</b>",
    "tooltip": false,
    "on-click": "better-control"
   },

  "group/windows": {
    "orientation": "horizontal",
    "modules": ["custom/windowexpand", "custom/closewindow", "custom/maxwindow", "custom/floatwindow"],
    "drawer": {
        "transition-duration": 500,
        "transition-left-to-right": true,
        "children-class": "minimized"
     }
   },

   "group/minimized": {
    "orientation": "horizontal",
    "modules": ["custom/trayexpand", "tray"],
    "drawer": {
        "transition-duration": 500,
	"transition-left-to-right": false,
	"children-class": "minimized"
     }
   },
   
   "group/clickable": {
    "orientation": "horizontal",
    "modules": ["custom/appexpand", "backlight", "pulseaudio", "bluetooth", "network"],
    "drawer": {
        "transition-duration": 500,
	"transition-left-to-right": false,
	"children-class": "minimized"
     }
   },

   "custom/closewindow": {
    "tooltip": false,
    "format": "п‘§ ",
    "on-click": "hyprctl dispatch killactive"
   },

   "custom/maxwindow": {
    "tooltip": false,
    "format": "о©І",
    "on-click": "hyprctl dispatch fullscreen 1"
   },

   "custom/floatwindow": {
    "tooltip": false,
    "format": "вЂ‰п’‹",
    "on-click": "hyprctl dispatch togglefloating && hyprctl dispatch resizeactive exact 80% 80% && hyprctl dispatch centerwindow"
   },

   "custom/notification": {
    "tooltip": false,
    "format": "{icon}",
    "format-icons": {
      "notification": "пѓі",
      "none": "п‚ў",
      "dnd-notification": "п‡¶",
      "dnd-none": "п‡¶",
      "inhibited-notification": "пѓі",
      "inhibited-none": "п‚ў",
      "dnd-inhibited-notification": "п‡·",
      "dnd-inhibited-none": "п‡·"
    },
    "return-type": "json",
    "exec-if": "which swaync-client",
    "exec": "swaync-client -swb",
    "on-click": "swaync-client -t -sw",
    "on-click-right": "swaync-client -d -sw",
    "escape": true
  }
}]
